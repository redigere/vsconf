{
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.sideBar.location": "right",
    "workbench.layoutControl.enabled": false,
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.startupEditor": "none",
    "workbench.welcomePage.walkthroughs.openOnInstall": false,
    "workbench.tips.enabled": false,
    "workbench.editor.labelFormat": "short",
    "workbench.tree.indent": 16,
    "workbench.list.smoothScrolling": true,
    "workbench.activityBar.location": "side",

    "window.commandCenter": false,
    "window.menuBarVisibility": "toggle",
    "window.titleBarStyle": "custom",
    "window.density.editorTabHeight": "compact",
    "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",
    "window.dialogStyle": "custom",

    "editor.minimap.enabled": false,
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.horizontal": "auto",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.hideCursorInOverviewRuler": true,
    "editor.glyphMargin": false,
    "editor.stickyScroll.enabled": true,
    "editor.fontSize": 14,
    "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'Fira Code', monospace",
    "editor.fontLigatures": true,
    "editor.fontWeight": "400",
    "editor.letterSpacing": 0.3,
    "editor.lineHeight": 22,
    "editor.lineNumbers": "relative",
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorWidth": 2,
    "editor.smoothScrolling": true,
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.guides.indentation": true,
    "editor.renderWhitespace": "boundary",
    "editor.renderLineHighlight": "gutter",
    "editor.linkedEditing": true,
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",
    "editor.autoIndent": "advanced",
    "editor.suggest.showKeywords": true,
    "editor.suggest.showSnippets": true,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.inlineSuggest.enabled": false,
    "editor.parameterHints.enabled": true,
    "editor.occurrencesHighlight": "singleFile",
    "editor.selectionHighlight": true,
    "editor.codeLens": false,
    "editor.folding": true,
    "editor.foldingStrategy": "indentation",
    "editor.showFoldingControls": "mouseover",
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    "editor.rulers": [80, 120],
    "editor.overviewRulerBorder": false,

    "terminal.integrated.fontFamily": "'Cascadia Code', 'JetBrains Mono', 'Consolas', monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.decorationsEnabled": "both",
    "terminal.integrated.suggest.enabled": true,
    "terminal.integrated.suggest.quickSuggestions": true,
    "terminal.integrated.suggest.suggestOnTriggerCharacters": true,
    "terminal.integrated.stickyScroll.enabled": true,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Git Bash": {
            "path": "C:\\Program Files\\Git\\bin\\bash.exe",
            "icon": "terminal-bash"
        },
        "CMD": {
            "path": "cmd.exe",
            "icon": "terminal-cmd"
        },
        "WSL": {
            "path": "wsl.exe",
            "icon": "terminal-ubuntu"
        }
    },

    "explorer.openEditors.visible": 0,
    "explorer.confirmDelete": true,
    "explorer.confirmDragAndDrop": true,
    "explorer.compactFolders": false,
    "explorer.decorations.badges": true,
    "explorer.decorations.colors": true,
    "explorer.sortOrder": "type",

    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true,
        "**/target": true,
        "**/__pycache__": true,
        "**/.venv": true,
        "**/vendor": true
    },

    "files.autoSave": "onFocusChange",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "files.eol": "\r\n",
    "files.exclude": {
        "**/.git": true,
        "**/.vscode": true,
        "**/Thumbs.db": true,
        "**/Desktop.ini": true,
        "**/*.lnk": true
    },

    "terminal.integrated.env.windows": {
        "PATH": "${env:PATH}"
    },

    "telemetry.telemetryLevel": "off",
    "telemetry.enableTelemetry": false,
    "telemetry.enableCrashReporter": false,
    "crashReporter.showTelemetryMessage": false,

    "github.copilot.enable": { "*": false },
    "github.copilot.editor.enableAutoCompletions": false,
    "chat.editor.enable": false,
    "inlineChat.enabled": false,
    "workbench.commandPalette.experimental.suggestCommands": false,
    "github.copilot.chat.localeOverride": "en",
    "github.copilot.advanced": { "inlineSuggestCount": 0 },
    "workbench.agent.enabled": false,
    "chat.enabled": false,
    "chat.voiceChat.enabled": false,
    "chat.editing.enabled": false,
    "chat.agent.enabled": false,
    "workbench.grunt.hooks.enable": false,
    "workbench.npm.hooks.enable": false,

    "update.mode": "none",
    "update.showReleaseNotes": false,
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": true,

    "extensions.gallery.serviceUrl": "http://127.0.0.1:65535",
    "extensions.gallery.itemUrl": "http://127.0.0.1:65535",
    "extensions.gallery.resourceUrlTemplate": "http://127.0.0.1:65535/resource/{publisher}/{name}/{version}/{path}",

    "security.workspace.trust.enabled": true,
    "security.workspace.trust.startupPrompt": "always",

    "git.enableSmartCommit": false,
    "git.autofetch": false,
    "git.confirmSync": true,
    "git.openRepositoryInParentFolders": "never",
    "git.path": "C:\\Program Files\\Git\\bin\\git.exe",

    "http.proxyStrictSSL": true,

    "[json]": { "editor.defaultFormatter": "vscode.json-language-features" },
    "[jsonc]": { "editor.defaultFormatter": "vscode.json-language-features" },
    "[javascript]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
    "[typescript]": { "editor.defaultFormatter": "vscode.typescript-language-features" },
    "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[scss]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[markdown]": { "editor.defaultFormatter": "yzhang.markdown-all-in-one" },
    "[python]": { "editor.defaultFormatter": "ms-python.python" },
    "[cpp]": { "editor.defaultFormatter": "ms-vscode.cpptools", "editor.semanticHighlighting.enabled": true },
    "[c]": { "editor.defaultFormatter": "ms-vscode.cpptools", "editor.semanticHighlighting.enabled": true },
    "[java]": { "editor.defaultFormatter": "redhat.java" },
    "[go]": { "editor.defaultFormatter": "golang.go", "editor.codeActionsOnSave": { "source.organizeImports": "always" } },
    "[rust]": { "editor.defaultFormatter": "rust-lang.rust-analyzer", "editor.semanticHighlighting.enabled": true },
    "[kotlin]": { "editor.defaultFormatter": "fwcd.kotlin" },
    "[terraform]": { "editor.defaultFormatter": "hashicorp.terraform" },
    "[shellscript]": { "editor.defaultFormatter": "foxundermoon.shell-format" },
    "[yaml]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
    "[powershell]": { "editor.defaultFormatter": "ms-vscode.powershell" },
    "[bat]": { "editor.defaultFormatter": "ms-vscode.powershell" }
}
